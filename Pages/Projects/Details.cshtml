@page "{slug?}"
@model Bitcoin_Treasury_.NET.Pages.Projects.DetailsModel
@{
    ViewData["Title"] = Model.ProjectName ?? "Project Detail";
}

<div class="dashboard-wrapper animate-fade-in">
    <div class="liquid-glass-panel mt-5">
        <div class="panel-header-row mb-4">
            <a asp-page="/Community" class="hero-inline-link">← Back</a>
            <button class="zap-btn zap-btn-lg"><span class="zap-icon">⚡</span> Zap Sats via LN</button>
        </div>
        
        <div class="project-detail-hero">
            <span class="ticker-identity">ACTIVE DEVELOPMENT</span>
            <h1 class="main-crypto-price">@Model.ProjectName</h1>
            <p class="sync-text">PROTOCOL IMPLEMENTATION PROJECT</p>
        </div>

        <div class="metrics-dashboard-grid mb-5">
            <div class="metric-item">
                <span class="metric-label">TOTAL RAISED</span>
                <span class="metric-value">₿ 1.15 M</span>
            </div>
            <div class="metric-item">
                <span class="metric-label">ACTIVE CONTRIBUTORS</span>
                <span class="metric-value">45<span class="summary-sublabel ms-1">DEVS</span></span>
            </div>
            <div class="metric-item">
                <span class="metric-label">IMPACT SCORE (BETA)</span>
                <span class="metric-value native-up">88%<span class="arrow-up ms-1">▲</span></span>
            </div>
            <div class="metric-item">
                <span class="metric-label">VALIDATION STATE</span>
                <span class="metric-value">TESTNET_A</span>
            </div>
        </div>

        <div class="community-secondary-row">
            <div class="secondary-title-block">
                <h2 class="focus-heading">Technical Specifications & Consensus Alignment</h2>
            </div>
            <article class="secondary-desc-block paragraph-text story-content-body">
                @if (Model.ProjectDescription != null)
                {
                    @Html.Raw(Model.ProjectDescription)
                }
                else
                {
                    <div class="skeleton loading-cell" style="width: 100%; height: 200px;"></div>
                    <p>Fetching protocol details from GitHub Collective...</p>
                }
            </article>
        </div>

        <section class="mt-5 pt-5 border-top border-secondary-subtle" id="comments">
            <h3 class="treasury-section-title mb-4">💬 Contributor Discussion</h3>
            
            <div class="skeleton-wrapper">
                <div class="skeleton loading-cell mb-2" style="width: 100%; height: 60px;"></div>
                <div class="skeleton loading-cell mb-2" style="width: 90%; height: 60px;"></div>
            </div>
            
            <div class="add-comment-mock mt-4">
                <textarea class="form-control bg-transparent paragraph-text border-secondary" placeholder="Add your perspective to the BIP-340 validation..." rows="3"></textarea>
                <button class="hero-inline-link mt-2">Publish Contributor Note</button>
            </div>
        </section>
    </div>
</div>