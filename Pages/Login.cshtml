@page
@model Bitcoin_Treasury_.NET.Pages.LoginModel
@{
    ViewData["Title"] = "Access Node";
}

<div class="dashboard-wrapper auth-wrapper animate-fade-in">
    <div class="crypto-card liquid-glass-panel auth-card">
        
        <div class="text-center mb-4">
            <div class="auth-brand-logo mb-2">₿</div>
            <h2 class="treasury-section-title m-0">Access Node</h2>
            <p class="treasury-section-subtitle mt-1">Authenticate credential payload to initialize workspace</p>
        </div>

        <form method="post" class="auth-form-flow">
            <div class="form-group-field mb-3">
                <label for="identity-payload" class="metric-label mb-2">OPERATOR IDENTITY / EMAIL</label>
                <div class="input-glass-container">
                    <span class="input-addon-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                    </span>
                    <input type="text" id="identity-payload" name="IdentityPayload" placeholder="operator@cypherpunk.net" class="glass-form-control" required autocomplete="username" />
                </div>
            </div>

            <div class="form-group-field mb-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <label for="security-key" class="metric-label m-0">PASSPHRASE / KEY</label>
                    <a href="#forgot" class="auth-context-link">Recover Key</a>
                </div>
                <div class="input-glass-container">
                    <span class="input-addon-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                    </span>
                    <input type="password" id="security-key" name="Passphrase" placeholder="••••••••••••" class="glass-form-control" required autocomplete="current-password" />
                </div>
            </div>

            <button type="submit" class="auth-submit-btn">
                <span>Authorize Payload</span>
                <span class="btn-arrow">→</span>
            </button>
        </form>

        <div class="text-center mt-4 pt-3 border-top border-secondary-subtle">
            <span class="sync-text">NEW STATION OPERATOR? </span>
            <a href="#register" class="hero-inline-link font-size-sm ms-1">Request Workspace access <span class="arrow-diagonal">↗</span></a>
        </div>
    </div>
</div>