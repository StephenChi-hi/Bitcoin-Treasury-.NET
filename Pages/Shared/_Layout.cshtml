<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bitcoin_Treasury_.NET</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Bitcoin-Treasury-.NET.styles.css" asp-append-version="true" />
    
</head>
<body>
    <!-- Splash Screen -->
    <div id="splash-screen">
        <div id="splash-logo">₿</div>
        <div id="splash-text">
            <span style="animation-delay: 0s">B</span>
            <span style="animation-delay: 0.08s">i</span>
            <span style="animation-delay: 0.16s">t</span>
            <span style="animation-delay: 0.24s">c</span>
            <span style="animation-delay: 0.32s">o</span>
            <span style="animation-delay: 0.40s">i</span>
            <span style="animation-delay: 0.48s">n</span>
            <span style="animation-delay: 0.56s"> </span>
            <span style="animation-delay: 0.64s">T</span>
            <span style="animation-delay: 0.72s">r</span>
            <span style="animation-delay: 0.80s">e</span>
            <span style="animation-delay: 0.88s">a</span>
            <span style="animation-delay: 0.96s">s</span>
            <span style="animation-delay: 1.04s">u</span>
            <span style="animation-delay: 1.12s">r</span>
            <span style="animation-delay: 1.20s">y</span>
        </div>
        <div id="splash-percentage">0%</div>
    </div>
      <script src="~/js/splash.js" asp-append-version="true" defer></script>

    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">Bitcoin_Treasury_.NET</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer justify-center bottom-0 w-full flex text-muted">
        <div class="container">
            &copy; 2026 - Bitcoin_Treasury_.NET - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
